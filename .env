# Open-Meteo and Nominatim APIs are currently free and don't require an active API Key.
# However, the base URLs and placeholder keys have been extracted here safely.

VITE_WEATHER_API_BASE_URL="https://api.open-meteo.com/v1"
VITE_GEOCODE_API_BASE_URL="https://geocoding-api.open-meteo.com/v1"
VITE_NOMINATIM_API_BASE_URL="https://nominatim.openstreetmap.org"

# Place any future API Keys below (e.g. if you migrate to OpenWeatherMap)
VITE_WEATHER_API_KEY=""
